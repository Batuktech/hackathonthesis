NODE_ENV=production

# Public app URL and API URL used by the browser build.
APP_DOMAIN=thesis.example.com
NEXT_PUBLIC_API_URL=https://thesis.example.com/api
CORS_ORIGIN=https://thesis.example.com

# PostgreSQL. Use a strong password on the VPS.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=thesis_orchestral
DATABASE_URL=postgresql://postgres:replace-with-strong-postgres-password@postgres:5432/thesis_orchestral

# Backend runtime.
JWT_SECRET=replace-with-long-random-secret
UPLOAD_DIR=uploads
LOG_LEVEL=info
